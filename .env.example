# Node environment (development | production)
NODE_ENV=development

# TLS certificate paths (defaults to ~/.augmentedCC/certs/)
# CERT_PATH=
# KEY_PATH=

# Deepgram speech-to-text API key (https://console.deepgram.com)
DEEPGRAM_API_KEY=

# OpenRouter LLM API key (https://openrouter.ai/keys)
OPENROUTER_KEY=
